   "source": [
    "# List and Array\n",
    "\n",
    "List is a mutable sequence of values."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "0ffd101c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sum = 15\n"
     ]
    }
   ],
   "source": [
    "n_list = [1, 2, 3, 4, 5]\n",
    "s = 0\n",
    "\n",
    "for elm in n_list:\n",
    "    s += elm\n",
    "\n",
    "print('Sum =', s)"
   ]
  },
